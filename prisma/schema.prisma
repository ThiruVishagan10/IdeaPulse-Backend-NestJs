// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  idea Idea[]
}

model Idea {
  id             String     @id @default(uuid())
  userId         String
  status         IdeaStatus @default(ACTIVE)
  currentVersion Int        @default(0) //Atomic---> Either complete Entirely or not at all 
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  version IdeaVersion[]

  @@index([userId])
}

model IdeaVersion {
  id              String        @id @default(uuid())
  ideaId          String
  version         Int
  title           String
  content         String
  createdAt       DateTime      @default(now())
  sourceType      VersionSource @default(USER)
  aiResultId      String?
  parentVersionId String?

  idea      Idea       @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  aiResults AIResult[]

  @@unique([ideaId, version])
  @@index([ideaId, version(sort: Desc)])
}

model AIResult {
  id            String       @id @default(uuid())
  ideaVersionId String
  type          AIResultType
  prompt        String
  response      String
  createdAt     DateTime     @default(now())

  ideaVersion IdeaVersion @relation(fields: [ideaVersionId], references: [id], onDelete: Cascade)

  @@index([ideaVersionId])
}

enum VersionSource {
  USER
  AI
}

enum AIResultType {
  SUGGESTION
  SUMMARY
  ENHANCEMENT
  ANALYSIS
}

enum IdeaStatus {
  ACTIVE
  ARCHIVED
  DELETED
}
