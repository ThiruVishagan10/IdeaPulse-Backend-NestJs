// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  idea Idea[]
}

//////////////////////////////////////////////////////
// IDEA (Vault Container)
//////////////////////////////////////////////////////

model Idea {
  id             String     @id @default(uuid())
  userId         String
  status         IdeaStatus @default(ACTIVE)
  currentVersion Int        @default(0) //Atomic---> Either complete Entirely or not at all 
  isFavorite     Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  version   IdeaVersion[]
  airesults AIResult[]

  @@index([status])
  @@index([userId])
}

//////////////////////////////////////////////////////
// IDEA VERSION (Immutable Snapshot)
//////////////////////////////////////////////////////

model IdeaVersion {
  id      String @id @default(uuid())
  ideaId  String
  version Int
  title   String
  content String

  sourceType      VersionSource @default(USER)
  aiResultId      String?
  parentVersionId String?

  createdAt DateTime @default(now())

  idea      Idea       @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  aiResults AIResult[]

  @@unique([ideaId, version])
  @@index([ideaId, version(sort: Desc)])
}

//////////////////////////////////////////////////////
// AI RESULT (Workspace + Vault Integration)
//////////////////////////////////////////////////////

model AIResult {
  id String @id @default(uuid())

  ideaId        String?
  ideaVersionId String?

  domain AIDomain
  tool   String

  input    Json?
  response Json

  modelUsed   String?
  temperature Float?

  createdAt DateTime @default(now())

  ideaVersion IdeaVersion? @relation(fields: [ideaVersionId], references: [id], onDelete: Cascade)
  idea        Idea?        @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@index([ideaId])
  @@index([ideaVersionId])
  @@index([domain])
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum VersionSource {
  USER
  AI
}

enum AIDomain {
  IDEA_STUDIO
  ANALYZER
  MOODBOARD
  IDEA_VAULT
}

enum IdeaStatus {
  ACTIVE
  ARCHIVED
  DELETED
}
